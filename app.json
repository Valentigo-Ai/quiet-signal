{
  "expo": {
    "name": "Quiet Signal",
    "slug": "quiet-signal",
    "scheme": "quietsignal",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/brand/icon.png",
    "splash": {
      "backgroundColor": "#0B1128",
      "image": "./assets/brand/splash.png",
      "resizeMode": "contain"
    },
    "android": {
      "package": "com.quietsignal.app",
      "adaptiveIcon": {
        "foregroundImage": "./assets/brand/adaptive-icon.png",
        "backgroundColor": "#0B1128"
      },
      "permissions": [
        "NOTIFICATIONS"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-localization",
      [
        "expo-splash-screen",
        {
          "image": "./assets/brand/splash.png",
          "backgroundColor": "#0B1128",
          "imageWidth": 220
        }
      ],
      "expo-font",
      "expo-web-browser",
      [
        "expo-navigation-bar",
        {
          "barStyle": "light",
          "enforceContrast": false
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "8ed99a7a-8db8-4d54-9135-be7079dad996"
      }
    },
    "owner": "valentigo",
    "ios": {
      "bundleIdentifier": "com.quietsignal.app",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "web": {
      "favicon": "./assets/brand/icon.png",
      "bundler": "metro",
      "name": "Quiet Signal"
    },
    "experiments": {
      "baseUrl": "/app"
    }
  }
}
